# === Neo4j ===
# Local development: bolt://localhost:7687
# Docker Compose: bolt://neo4j:7687 (set automatically by docker-compose.yml)
# AuraDB: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_CONNECT_TIMEOUT=90

# === PostgreSQL ===
# Local development: localhost
# Docker Compose: postgres (set automatically by docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=graphrag
POSTGRES_PASSWORD=graphrag123
POSTGRES_DB=graphrag_meta

# === LLM API Keys ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4o-mini

# === Local Search (B mode) ===
LOCAL_SEARCH_MODEL=gpt-4o
LOCAL_SEARCH_MAX_TOKENS=2048
LOCAL_SEARCH_DEFAULT_DEPTH=2
LOCAL_SEARCH_MAX_NODES=50

# === App Settings ===
APP_ENV=development
DDL_MAX_SIZE_MB=10
CSV_MAX_FILE_SIZE_MB=50
CSV_MAX_FILES=50

# === Auth (optional) ===
# Single-tenant: set APP_API_KEY
APP_API_KEY=
# Multi-tenant: set TENANT_KEYS as JSON ({"key1": "tenant_a", ...})
TENANT_KEYS=

# === CORS (production) ===
CORS_ORIGINS=http://localhost:3000
